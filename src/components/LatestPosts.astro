---
import { myResume } from "../data/resume";
---

<section
  id="posts"
  class="py-12 sm:py-16 md:py-20 bg-gray-50 dark:bg-gray-800 transition-colors duration-300"
>
  <div class="container mx-auto px-4">
    <h2 class="text-2xl sm:text-3xl font-bold mb-8 sm:mb-12 text-center fade-in">
      Latest Posts
    </h2>

    <div class="max-w-4xl mx-auto grid gap-4 sm:gap-6 md:grid-cols-2">
      {
        myResume.latestPosts.map((post) => (
          <article class="bg-white dark:bg-gray-900 rounded-lg p-4 sm:p-6 shadow-md transition-all duration-300 hover:shadow-lg fade-in h-full flex flex-col">
            <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium mb-2">
              {post.date}
            </p>

            <h3 class="text-lg sm:text-xl font-bold mb-3">{post.title}</h3>

            <p class="text-base text-gray-700 dark:text-gray-300 mb-4 flex-1">
              {post.description}
            </p>

            <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-4">
              {post.tags.map((tag) => (
                <span class="px-1.5 sm:px-2 py-0.5 sm:py-1 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-300 rounded text-xs sm:text-base">
                  {tag}
                </span>
              ))}
            </div>

            <a
              href={post.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Read ${post.title} on LinkedIn`}
              class="inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium transition-colors text-base"
            >
              Read on LinkedIn
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
